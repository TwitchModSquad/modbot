<a class="twitch-user" href="<%= locals?.twitchLink ? "https://twitch.tv/" + account.login : "/panel/user/" + account.id %>"<%- locals?.twitchLink ? ' target="__blank"' : "" %>><img src="<%= account.profile_image_url %>" /><div class="user-info"><div class="user-name"><%= account.display_name %></div><div class="user-stats"><%= account.id %> <span class="bullet">&bullet;</span> <%= account.follower_count %>&nbsp;follower<%= account.follower_count == 1 ? "" : "s"%> <span class="bullet">&bullet;</span> <%= account.view_count %>&nbsp;view<%= account.view_count == 1 ? "" : "s" %></div></div></a>
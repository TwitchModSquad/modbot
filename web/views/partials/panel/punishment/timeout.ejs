<div class="punishment timeout"><% if (!locals.hideTimedOut) { %><div class="user-timeout"><h3>User Timed Out</h3><img src="<%= timeout.user.profile_image_url %>" alt="<%= timeout.user.display_name %> profile picture"><%= timeout.user.display_name %></div><% } if (!locals.hideTimedOutIn) { %><div class="timeout-in"><h3>Timed Out In</h3><img src="<%= timeout.channel.profile_image_url %>" alt="<%= timeout.channel.display_name %> profile picture"><%= timeout.channel.display_name %></div><% } %><div class="timestamp"><h3>Time Timed Out</h3><%= new Date(timeout.time).toLocaleString() %> for <%= comma(timeout.duration) %> second<%= timeout.duration === 1 ? "" : "s" %></div><div class="status"><h3>Status</h3><%= timeout.active ? "Active" : "Inactive" %></div><div class="view-log"><h3>View Chat History</h3><a href="/panel/chat-history?streamer=<%= timeout.channel.id %>&chatter=<%= timeout.user.id %>&endtime=<%= timeout.time %>">View Chat Log</a></div></div>
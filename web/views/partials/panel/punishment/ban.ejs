<div class="punishment ban"><% if (!locals.hideBanned) { %><div class="user-banned"><h3>User Banned</h3><img src="<%= ban.user.profile_image_url %>" alt="<%= ban.user.display_name %> profile picture"><%= ban.user.display_name %></div><% } if (!locals.hideBannedIn) { %><div class="banned-in"><h3>Banned In</h3><img src="<%= ban.channel.profile_image_url %>" alt="<%= ban.channel.display_name %> profile picture"><%= ban.channel.display_name %></div><% } %><div class="timestamp"><h3>Time Banned</h3><%= new Date(ban.time).toLocaleString() %></div><div class="status"><h3>Status</h3><%= ban.active ? "Active" : "Inactive" %></div><div class="view-log"><h3>View Chat History</h3><a href="/panel/chat-history?streamer=<%= ban.channel.id %>&chatter=<%= ban.user.id %>&endtime=<%= ban.time %>">View Chat Log</a></div></div>